<ui:FluentWindow x:Class="Grafiton.MainWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
                  xmlns:viewmodels="clr-namespace:Grafiton.ViewModels"
                  xmlns:views="clr-namespace:Grafiton.Views"
                  mc:Ignorable="d"
                  Title="{Binding WindowTitle}" 
                  Icon="pack://application:,,,/Resources/logo.ico"
                  Height="720" Width="1100"
                  WindowStartupLocation="CenterScreen"
                  WindowBackdropType="Mica"
                  ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type viewmodels:WelcomeViewModel}">
            <views:WelcomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ViewerViewModel}">
            <views:ViewerView/>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="{Binding WindowTitle}">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <ui:TextBlock Text="Grafiton" FontTypography="Body" FontWeight="Bold"/>
                </StackPanel>
            </ui:TitleBar.Header>

            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal">
                    <ui:Button Icon="{Binding ThemeIcon}" 
                               Appearance="Transparent" 
                               ToolTip="Changer de thème (Clair / Sombre)" 
                               Margin="0,0,8,0"
                               Command="{Binding ToggleThemeCommand}"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- Main View Dynamic Area -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
    </Grid>
</ui:FluentWindow>
