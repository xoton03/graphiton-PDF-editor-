<Window x:Class="Grafiton.Views.HeaderFooterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        xmlns:vm="clr-namespace:Grafiton.ViewModels"
        mc:Ignorable="d"
        Title="En-têtes, Pieds de page &amp; Numérotation" 
        Height="500" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Ajouter en-tête / pied de page et numérotation" FontTypography="Title" FontSize="22" FontWeight="Bold"/>
            <ui:TextBlock Text="Insérez du texte répété et des numéros de pages dynamiques sur votre document." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Form Controls -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- Header text -->
            <ui:TextBlock Text="Texte de l'en-tête (haut de page) :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,12"/>

            <!-- Footer text -->
            <ui:TextBlock Text="Texte du pied de page (bas de page) :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding FooterText, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,12"/>

            <!-- Page Numbering options -->
            <CheckBox Content="Inclure la numérotation automatique des pages" IsChecked="{Binding IncludePageNumbers}" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ui:TextBlock Text="Format du numéro :" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PageNumberFormat, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <ui:TextBlock Text="Plage de pages :" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PageRange, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Footer Actions -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Annuler" Margin="0,0,12,0" Command="{Binding CloseCommand}"/>
                <ui:Button Content="Appliquer au document" Icon="Checkmark24" Appearance="Primary"
                           FontSize="15" Padding="20,8" Command="{Binding ApplyHeaderFooterCommand}"/>
            </StackPanel>
            <ui:TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
