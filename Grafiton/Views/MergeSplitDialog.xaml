<Window x:Class="Grafiton.Views.MergeSplitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        mc:Ignorable="d"
        Title="Fusion &amp; Scission de PDF" 
        Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Fusion &amp; Scission" FontTypography="Title" FontSize="22" FontWeight="Bold"/>
            <ui:TextBlock Text="Combinez plusieurs PDF ou extrayez des plages de pages précises." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Tabbed Interface -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- Tab 1: Fusionner -->
            <TabItem Header="Fusionner des PDF">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:Button Content="Ajouter des fichiers" Icon="Add24" Appearance="Primary" Margin="0,0,8,0"
                                   Command="{Binding AddFilesToMergeCommand}"/>
                        <ui:Button Content="Retirer la sélection" Icon="Delete24" Appearance="Secondary"
                                   Command="{Binding RemoveFileToMergeCommand}"/>
                    </StackPanel>

                    <Border Grid.Row="1" CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Padding="4">
                        <ListBox ItemsSource="{Binding FilesToMerge}" SelectedItem="{Binding SelectedFileToMerge}"
                                 Background="Transparent" BorderThickness="0" Padding="4"/>
                    </Border>

                    <ui:Button Grid.Row="2" Content="Fusionner les PDF" Icon="DocumentCopy24" Appearance="Primary"
                               FontSize="15" Padding="24,10" HorizontalAlignment="Right" Margin="0,16,0,0"
                               Command="{Binding ExecuteMergeCommand}"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Scinder -->
            <TabItem Header="Scinder un PDF">
                <Grid Margin="0,16,0,0">
                    <StackPanel>
                        <ui:TextBlock Text="Fichier PDF source :" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SplitSourceFile}" IsReadOnly="True" Margin="0,0,8,0" Padding="8"/>
                            <ui:Button Grid.Column="1" Content="Parcourir" Icon="FolderOpen24" Command="{Binding SelectSplitSourceCommand}"/>
                        </Grid>

                        <ui:TextBlock Text="Plage de pages à extraire (ex: 1-3, 5, 8-10) :" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding PageRangeExpression}" Padding="8" Margin="0,0,0,24"/>

                        <ui:Button Content="Extraire et sauvegarder" Icon="FolderZip24" Appearance="Primary"
                                   FontSize="15" Padding="24,10" HorizontalAlignment="Right"
                                   Command="{Binding ExecuteSplitCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <ui:TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemAccentColorBrush}"
                      FontWeight="SemiBold" Margin="0,12,0,0"/>
    </Grid>
</Window>
