<Window x:Class="Grafiton.Views.WatermarkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        mc:Ignorable="d"
        Title="Ajouter un filigrane" 
        Height="480" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Ajouter un filigrane" FontTypography="Title" FontSize="22" FontWeight="Bold"/>
            <ui:TextBlock Text="Personnalisez le filigrane texte et prévisualisez le rendu en temps réel." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 2 Columns: Controls on left, Live Preview on right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Controls -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <!-- Watermark Text Input -->
                <ui:TextBlock Text="Texte du filigrane :" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10" Margin="0,0,0,16"/>

                <!-- Opacity Slider with Numerical Display -->
                <Grid Margin="0,0,0,6">
                    <ui:TextBlock Text="Opacité (transparence) :" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <ui:TextBlock Text="{Binding OpacityPercent, StringFormat='{}{0}%'}" 
                                  FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorBrush}" 
                                  HorizontalAlignment="Right"/>
                </Grid>
                <Slider Minimum="0.1" Maximum="1.0" Value="{Binding Opacity}" 
                        TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,0,0,16"/>

                <!-- Rotation Angle Slider with Numerical Display -->
                <Grid Margin="0,0,0,6">
                    <ui:TextBlock Text="Inclinaison (angle) :" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <ui:TextBlock Text="{Binding FormattedAngle, StringFormat='{}{0}°'}" 
                                  FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorBrush}" 
                                  HorizontalAlignment="Right"/>
                </Grid>
                <Slider Minimum="-90" Maximum="90" Value="{Binding RotationAngle}" 
                        TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,0,16"/>
            </StackPanel>

            <!-- Column 2: Live Preview Card -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:TextBlock Grid.Row="0" Text="Aperçu en direct" FontTypography="Caption" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                    <!-- Simulated Paper Sheet with rotated live watermark text -->
                    <Border Grid.Row="1" Background="White" CornerRadius="4" ClipToBounds="True">
                        <Grid>
                            <!-- Simulated Document lines -->
                            <StackPanel Margin="16" Opacity="0.2">
                                <Rectangle Height="12" Fill="Gray" Margin="0,0,40,8"/>
                                <Rectangle Height="8" Fill="Gray" Margin="0,0,10,6"/>
                                <Rectangle Height="8" Fill="Gray" Margin="0,0,20,6"/>
                                <Rectangle Height="8" Fill="Gray" Margin="0,0,0,6"/>
                                <Rectangle Height="8" Fill="Gray" Margin="0,0,30,16"/>
                                <Rectangle Height="8" Fill="Gray" Margin="0,0,15,6"/>
                                <Rectangle Height="8" Fill="Gray" Margin="0,0,5,6"/>
                            </StackPanel>

                            <!-- Live Rotated & Transparent Watermark Text -->
                            <Viewbox Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding WatermarkText}" 
                                           FontWeight="Bold" 
                                           Foreground="DarkGray"
                                           Opacity="{Binding Opacity}">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding RotationAngle}" CenterX="0.5" CenterY="0.5"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.RenderTransformOrigin>
                                        <Point X="0.5" Y="0.5"/>
                                    </TextBlock.RenderTransformOrigin>
                                </TextBlock>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <ui:Button Content="Appliquer le filigrane" Icon="Stamp24" Appearance="Primary"
                       FontSize="15" Padding="24,10" HorizontalAlignment="Right"
                       Command="{Binding ApplyWatermarkCommand}"/>
            <ui:TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
