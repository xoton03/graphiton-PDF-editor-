<Window x:Class="Grafiton.Views.ExtractionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        xmlns:vm="clr-namespace:Grafiton.ViewModels"
        mc:Ignorable="d"
        Title="Extraction de contenu" 
        Height="420" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Extraire le contenu du PDF" FontTypography="Title" FontSize="22" FontWeight="Bold"/>
            <ui:TextBlock Text="Extrayez le texte brut ou toutes les images intégrées dans le document." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Main Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- Mode selection -->
            <ui:TextBlock Text="Type d'extraction :" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="Texte brut (.txt)" IsChecked="{Binding IsTextMode}" Margin="0,0,24,0"/>
                <RadioButton Content="Images intégrées (PNG/JPEG)" IsChecked="{Binding IsImagesMode}"/>
            </StackPanel>

            <!-- Page range -->
            <ui:TextBlock Text="Plage de pages (ex: all, 1-5, 2,4,8) :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding PageRange, UpdateSourceTrigger=PropertyChanged}" Padding="10" Margin="0,0,0,16"/>

            <!-- Output folder -->
            <ui:TextBlock Text="Dossier de destination :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" Padding="10" IsReadOnly="True"/>
                <ui:Button Grid.Column="1" Content="Parcourir..." Margin="8,0,0,0" Command="{Binding BrowseOutputDirectoryCommand}"/>
            </Grid>
        </StackPanel>

        <!-- Footer Actions -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Annuler" Margin="0,0,12,0" Command="{Binding CloseCommand}"/>
                <ui:Button Content="Lancer l'extraction" Icon="DocumentArrowRight24" Appearance="Primary"
                           FontSize="15" Padding="20,8" Command="{Binding StartExtractionCommand}"/>
            </StackPanel>
            <ui:TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
