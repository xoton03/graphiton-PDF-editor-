<UserControl x:Class="Grafiton.Views.ViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             xmlns:views="clr-namespace:Grafiton.Views"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Action & Annotation Toolbar -->
        <Border Grid.Row="0" 
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                BorderThickness="0,0,0,1" 
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="ArrowLeft24" 
                               Appearance="Secondary" 
                               ToolTip="Fermer le document" 
                               Margin="0,0,6,0"
                               Command="{Binding CloseDocumentCommand}"/>

                    <ui:Button Icon="FolderOpen24" 
                               Content="Ouvrir..." 
                               Appearance="Secondary" 
                               Margin="0,0,12,0"
                               Command="{Binding OpenAnotherPdfCommand}"/>

                    <ui:Button Icon="GroupList24" 
                               Content="Pages" 
                               Appearance="Secondary" 
                               Margin="0,0,12,0"
                               Command="{Binding TogglePagePanelCommand}"/>
                </StackPanel>

                <!-- Center Annotation Toolbar -->
                <views:AnnotationToolbar Grid.Column="1" 
                                         DataContext="{Binding AnnotationToolbarVM}" 
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center"/>

                <!-- Right Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="Layer24" 
                               Content="Lot" 
                               ToolTip="Traitement par lot de plusieurs PDF"
                               Appearance="Primary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowBatchDialogCommand}"/>

                    <ui:Button Icon="DocumentArrowRight24" 
                               Content="Extraire" 
                               ToolTip="Extraire du texte (.txt) ou des images"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowExtractionDialogCommand}"/>

                    <ui:Button Icon="Form24" 
                               Content="Formulaire" 
                               ToolTip="Remplir et enregistrer des formulaires PDF"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowFormFillDialogCommand}"/>

                    <ui:Button Icon="EyeOff24" 
                               Content="Masquer" 
                               ToolTip="Masquage définitif de zones confidentielles"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowRedactionDialogCommand}"/>

                    <ui:Button Icon="ArrowCompare24" 
                               Content="Comparer" 
                               ToolTip="Comparer 2 PDF en vue superposition d'images"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowComparisonViewCommand}"/>

                    <ui:Button Icon="NumberSymbol24" 
                               Content="Paginer" 
                               ToolTip="Ajouter numérotation, en-têtes et pieds de page"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowHeaderFooterDialogCommand}"/>

                    <ui:Button Icon="Signature24" 
                               Content="Signer" 
                               ToolTip="Apposer une signature visuelle"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowSignatureDialogCommand}"/>

                    <ui:Button Icon="ArrowSync24" 
                               Content="Convertir" 
                               ToolTip="Convertir ou compresser le document PDF"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowConversionDialogCommand}"/>

                    <ui:Button Icon="DocumentCopy24" 
                               Content="Pages" 
                               ToolTip="Fusionner ou scinder des documents PDF"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowMergeSplitDialogCommand}"/>

                    <ui:Button Icon="Stamp24" 
                               Content="Filigrane" 
                               ToolTip="Ajouter un filigrane au document"
                               Appearance="Secondary" 
                               Margin="0,0,4,0"
                               Command="{Binding ShowWatermarkDialogCommand}"/>

                    <ui:Button Icon="LockClosed24" 
                               Content="Sécurité" 
                               ToolTip="Protéger ou déprotéger par mot de passe"
                               Appearance="Secondary" 
                               Command="{Binding ShowPasswordDialogCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace (Page Manager Sidebar + WebView2 PDF Canvas) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Collapsible Left Panel -->
            <views:PageManagerPanel Grid.Column="0" 
                                    Width="260"
                                    DataContext="{Binding PageManagerVM}" 
                                    Visibility="{Binding DataContext.IsPagePanelOpen, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Central PDF Viewer -->
            <wv2:WebView2 x:Name="PdfWebView" 
                          Grid.Column="1" 
                          Source="{Binding SourceUri}"/>
        </Grid>
    </Grid>
</UserControl>
