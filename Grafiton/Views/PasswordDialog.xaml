<Window x:Class="Grafiton.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        mc:Ignorable="d"
        Title="Protéger le PDF par mot de passe" 
        Height="380" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Protection du document" FontTypography="Title" FontSize="20" FontWeight="Bold"/>
            <ui:TextBlock Text="Définissez un mot de passe requis pour ouvrir et lire ce document." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ui:TextBlock Text="Mot de passe d'ouverture :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding Password}" Padding="8" Margin="0,0,0,16"/>

            <ui:TextBlock Text="Confirmer le mot de passe :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding ConfirmPassword}" Padding="8" Margin="0,0,0,16"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <ui:Button Content="Protéger le PDF" Icon="LockClosed24" Appearance="Primary"
                       FontSize="15" Padding="20,10" HorizontalAlignment="Right"
                       Command="{Binding ProtectPdfCommand}"/>
            <ui:TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
