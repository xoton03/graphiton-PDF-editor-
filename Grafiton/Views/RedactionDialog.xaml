<Window x:Class="Grafiton.Views.RedactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        xmlns:vm="clr-namespace:Grafiton.ViewModels"
        mc:Ignorable="d"
        Title="Masquage définitif (Rédaction)" 
        Height="460" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Masquer du contenu confidentiel" FontTypography="Title" FontSize="22" FontWeight="Bold"/>
            <ui:TextBlock Text="Appliquez un rectangle de masquage opaque définitif sur la zone sélectionnée." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Form controls -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- Color Selection -->
            <ui:TextBlock Text="Couleur du masque de rédaction :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding AvailableColors}" SelectedItem="{Binding SelectedColor}" DisplayMemberPath="Name" Padding="8" Margin="0,0,0,16"/>

            <!-- Page Number -->
            <ui:TextBlock Text="Numéro de page (Index base 0) :" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding TargetPageIndex, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,16"/>

            <!-- Positions & Dimensions Grid -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ui:TextBlock Text="X (px) :" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PositionX, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <ui:TextBlock Text="Y (px) :" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PositionY, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <ui:TextBlock Text="Largeur :" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding AreaWidth, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <ui:TextBlock Text="Hauteur :" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding AreaHeight, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Footer Actions -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Annuler" Margin="0,0,12,0" Command="{Binding CloseCommand}"/>
                <ui:Button Content="Appliquer le masquage définitif" Icon="EyeOff24" Appearance="Primary"
                           FontSize="15" Padding="20,8" Command="{Binding ApplyRedactionCommand}"/>
            </StackPanel>
            <ui:TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
